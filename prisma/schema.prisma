generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Sin {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  episode     String?
  createdAt   DateTime @default(now())
}

model Progress {
  id        Int      @id @default(autoincrement())
  part      Int
  episode   Int?
  chapter   Int?
  notes     String?
  updatedAt DateTime @updatedAt
}

model RachelNote {
  id        Int      @id @default(autoincrement())
  content   String
  category  String
  createdAt DateTime @default(now())
}
